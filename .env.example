# Telegram bot token from @BotFather
BOT_TOKEN=

# OpenAI API key for analysis
ADMIN_IDS=
OPENAI_API_KEY=
MODEL=gpt-4o-mini

SQLITE_PATH=/app/data/bot.sqlite3

# Ограничьте количество треков, отправляемых модели, чтобы сэкономить токены
MAX_TRACKS=1200

# Яндекс Музыка через локальный SOCKS-туннель
YM_PROXY_HTTP=socks5h://127.0.0.1:9050
YM_PROXY_HTTPS=socks5h://127.0.0.1:9050

# SSH для туннеля
SSH_ADDR=root@home.kiselev.cz
SSH_PORT=902
YM_TIMEOUT=15
YM_RETRIES=3
YM_BACKOFF=0.5

PROMPT_CHUNK_SIZE=220
PROMPT_MAX_CHUNKS=20
PREVIEW_COUNT=30

# Реклама
AD_CONTACT=@pigeonvpn_bot
AD_TEXT=Твой надежный ВПН. Курлык: {contact}
AD_LINK=
